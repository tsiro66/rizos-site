---
import MainLayout from '../layouts/MainLayout.astro';
import ContactContent from '../components/pages/ContactContent.astro';
import { useTranslations } from '../i18n/utils';
import contactContent from '../content/contact.json';

const { t } = useTranslations('el', contactContent.el as Record<string, unknown>);
---

<MainLayout title={t('pageTitle') as string} t={t} locale='el'>
  <ContactContent t={t} locale='el' />
</MainLayout>
