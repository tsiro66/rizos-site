---
import MainLayout from '../layouts/MainLayout.astro';
import HomeContent from '../components/pages/HomeContent.astro';
import { useTranslations } from '../i18n/utils';
import homeContent from '../content/home.json';

const { t } = useTranslations('el', homeContent.el as Record<string, unknown>);
---

<MainLayout title={t('pageTitle') as string} transparentNav t={t} locale='el'>
  <HomeContent t={t} locale='el' />
</MainLayout>
