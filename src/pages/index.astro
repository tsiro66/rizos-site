---
import '../styles/global.css';
import { Font } from 'astro:assets';
---

<html lang="el">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<title>Rizos — Σύντομα Κοντά Σας</title>
		<Font cssVariable="--font-geologica" />
		<Font cssVariable="--font-alegreya" />
	</head>
	<body class="min-h-screen flex items-center justify-center bg-stone-50 text-stone-800">
		<div class="text-center px-6 py-12">
			<h1 class="font-geologica text-5xl md:text-7xl font-bold tracking-tight mb-4">
				Rizos
			</h1>
			<p class="font-alegreya text-xl md:text-2xl text-stone-500 mb-8">
				Σύντομα κοντά σας
			</p>
			<div class="w-16 h-px bg-stone-300 mx-auto"></div>
		</div>
	</body>
</html>
