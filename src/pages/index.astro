---
import '../styles/global.css';
import { Font } from 'astro:assets';
---

<html lang="el">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="Rizos — Traditional dairy products since 1940. Coming soon." />
		<title>Rizos — Coming soon</title>
		<Font cssVariable="--font-geologica" />
		<Font cssVariable="--font-alegreya" />
	</head>
	<body class="min-h-screen flex items-center justify-center text-stone-800 bg-stone-50">
		<div class="text-center px-6 py-16 animate-fade-in">
			<img
				src="/logo.png"
				alt="Rizos — Traditional dairy products"
				class="mx-auto mb-8 w-72 md:w-[28rem] drop-shadow-lg"
			/>

			<div class="flex items-center justify-center gap-3 mb-6">
				<span class="h-px w-12 bg-stone-300"></span>
				<p class="font-alegreya text-2xl md:text-3xl text-stone-600 tracking-wide">
					Coming soon
				</p>
				<span class="h-px w-12 bg-stone-300"></span>
			</div>

			<p class="font-geologica text-sm md:text-base text-stone-400 mb-10">
				Website is under construction. For orders and inquiries, please contact us at the phone number below.
			</p>

			<div class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-white shadow-sm border border-stone-200 hover:shadow-md transition-shadow">
				<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
				</svg>
				<a
					href="tel:+306944285782"
					class="font-geologica text-lg md:text-xl text-stone-700 hover:text-green-800 transition-colors no-underline"
				>
					694 428 5782
				</a>
			</div>
		</div>
	</body>
</html>

<style>
	@keyframes fade-in {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-fade-in {
		animation: fade-in 0.8s ease-out both;
	}
</style>
