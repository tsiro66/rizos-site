---
import MainLayout from '../../layouts/MainLayout.astro';
import ProductDetailContent from '../../components/pages/ProductDetailContent.astro';
import { useTranslations } from '../../i18n/utils';

const productModules = import.meta.glob<{ default: Record<string, any> }>('../../content/products/*.json', { eager: true });
const productMap: Record<string, any> = {};
for (const [path, mod] of Object.entries(productModules)) {
  const slug = path.split('/').pop()!.replace('.json', '');
  productMap[slug] = mod.default;
}

const elTitles: Record<string, string> = {
  feta: 'Φέτα Παραδοσιακή | Ρίζος',
  'leuko-turi': 'Λευκό Τυρί | Ρίζος',
  anthotiro: 'Ανθότυρο | Ρίζος',
  'graviera-ageladinh': 'Γραβιέρα Αγελάδινη | Ρίζος',
  'graviera-ageladinh-kefali': 'Γραβιέρα Αγελάδινη (Κεφάλι) | Ρίζος',
  'katsikisio-tyri': 'Κατσικίσιο Τυρί | Ρίζος',
  'kefaloturi-proveio': 'Κεφαλοτύρι Πρόβειο | Ρίζος',
  'paradosiako-proveio-giaourti-1kg': 'Πρόβειο Γιαούρτι 1kg | Ρίζος',
  'paradosiako-proveio-giaourti-250': 'Πρόβειο Γιαούρτι 250g | Ρίζος',
  'proveio-voutyro': 'Πρόβειο Βούτυρο | Ρίζος',
};

export function getStaticPaths() {
  const modules = import.meta.glob<{ default: Record<string, any> }>('../../content/products/*.json', { eager: true });
  const slugs: string[] = [];
  for (const [path] of Object.entries(modules)) {
    slugs.push(path.split('/').pop()!.replace('.json', ''));
  }
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const productData = productMap[slug!];
const localeData = productData.el as Record<string, unknown>;
const { t } = useTranslations('el', localeData);
const title = elTitles[slug!] ?? 'Ρίζος';
---

<MainLayout title={title} t={t} locale='el'>
  <ProductDetailContent t={t} locale='el' slug={slug} />
</MainLayout>