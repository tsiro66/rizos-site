---
import MainLayout from '../../layouts/MainLayout.astro';
import FactoryContent from '../../components/pages/FactoryContent.astro';
import { useTranslations, getStaticPaths, pageTitles } from '../../i18n/utils';
import factoryContent from '../../content/factory.json';

export { getStaticPaths };

const { locale } = Astro.params;
const localeData = (factoryContent as Record<string, Record<string, unknown>>)[locale!];
const { t } = useTranslations(locale!, localeData);
---

<MainLayout title={(pageTitles.factory as Record<string, string>)[locale!] ?? 'Rizos'} t={t} locale={locale!}>
  <FactoryContent t={t} locale={locale!} />
</MainLayout>