---
import MainLayout from '../../layouts/MainLayout.astro';
import ContactContent from '../../components/pages/ContactContent.astro';
import { useTranslations, getStaticPaths, pageTitles } from '../../i18n/utils';
import contactContent from '../../content/contact.json';

export { getStaticPaths };

const { locale } = Astro.params;
const localeData = (contactContent as Record<string, Record<string, unknown>>)[locale!];
const { t } = useTranslations(locale!, localeData);
---

<MainLayout title={(pageTitles.contact as Record<string, string>)[locale!] ?? 'Rizos'} t={t} locale={locale!}>
  <ContactContent t={t} locale={locale!} />
</MainLayout>