---
import MainLayout from '../../layouts/MainLayout.astro';
import ContactContent from '../../components/pages/ContactContent.astro';
import { useTranslations, getStaticPaths } from '../../i18n/utils';

export { getStaticPaths };

const { locale } = Astro.params;
const { t } = useTranslations(locale!);
---

<MainLayout title={t('contact.pageTitle')} t={t} locale={locale}>
  <ContactContent t={t} locale={locale} />
</MainLayout>
