---
import MainLayout from '../../../layouts/MainLayout.astro';
import ProductDetailContent from '../../../components/pages/ProductDetailContent.astro';
import { useTranslations } from '../../../i18n/utils';
import fetaContent from '../../../content/products/feta.json';
import leukoTuriContent from '../../../content/products/leuko-turi.json';

const productMap: Record<string, any> = {
  feta: fetaContent,
  'leuko-turi': leukoTuriContent,
};

export function getStaticPaths() {
  return [
    { params: { locale: 'en', slug: 'feta' } },
    { params: { locale: 'en', slug: 'leuko-turi' } },
    { params: { locale: 'de', slug: 'feta' } },
    { params: { locale: 'de', slug: 'leuko-turi' } },
  ];
}

const { locale, slug } = Astro.params;
const productData = productMap[slug!];
const localeData = productData[locale!] as Record<string, unknown>;
const { t } = useTranslations(locale!, localeData);
---

<MainLayout title={t('pageTitle') as string} t={t} locale={locale!}>
  <ProductDetailContent t={t} locale={locale!} slug={slug!} />
</MainLayout>
