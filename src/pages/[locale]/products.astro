---
import MainLayout from '../../layouts/MainLayout.astro';
import ProductsContent from '../../components/pages/ProductsContent.astro';
import { useTranslations, getStaticPaths, pageTitles } from '../../i18n/utils';
import productsContent from '../../content/products.json';

export { getStaticPaths };

const { locale } = Astro.params;
const localeData = (productsContent as Record<string, Record<string, unknown>>)[locale!];
const { t } = useTranslations(locale!, localeData);
---

<MainLayout title={(pageTitles.products as Record<string, string>)[locale!] ?? 'Rizos'} t={t} locale={locale!}>
  <ProductsContent t={t} locale={locale!} />
</MainLayout>