---
import MainLayout from '../layouts/MainLayout.astro';
import ProductsContent from '../components/pages/ProductsContent.astro';
import { useTranslations, pageTitles } from '../i18n/utils';
import productsContent from '../content/products.json';

const { t } = useTranslations('el', productsContent.el as Record<string, unknown>);
---

<MainLayout title={pageTitles.products.el} t={t} locale='el'>
  <ProductsContent t={t} locale='el' />
</MainLayout>