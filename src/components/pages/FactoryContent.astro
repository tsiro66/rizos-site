---
interface Props {
  t: <T = unknown>(key: string) => T;
  locale: string;
}

const { t } = Astro.props;
---

<!-- Hero -->
<section class="relative py-32 bg-stone-900 overflow-hidden">
  <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_70%_50%,_var(--tw-gradient-stops))] from-red-800 to-transparent"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <span class="text-sm font-geologica font-semibold tracking-widest uppercase text-red-300 mb-4 block">{t('hero.label')}</span>
    <h1 class="text-4xl md:text-6xl font-bold font-geologica text-white leading-tight">
      {t('hero.title')}
    </h1>
    <p class="mt-6 text-lg md:text-xl font-alegreya text-stone-300 max-w-2xl mx-auto leading-relaxed">
      {t('hero.subtitle')}
    </p>
  </div>
</section>

<!-- Overview -->
<section class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
    <div>
      <span class="text-sm font-geologica font-semibold tracking-widest uppercase text-red-800 mb-4 block">{t('overview.label')}</span>
      <h2 class="text-3xl md:text-4xl font-geologica font-bold text-stone-900 leading-tight">
        {t('overview.title')}
      </h2>
      <p class="mt-6 text-lg font-alegreya text-stone-600 leading-relaxed">
        {t('overview.para1')}
      </p>
      <p class="mt-4 text-lg font-alegreya text-stone-600 leading-relaxed">
        {t('overview.para2')}
      </p>
    </div>
    <div class="aspect-[4/3] bg-stone-200 rounded-2xl flex items-center justify-center">
      <span class="text-stone-400 font-geologica text-sm">{t('overview.imageAlt')}</span>
    </div>
  </div>
</section>

<!-- Features -->
<section class="py-24 bg-stone-50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-geologica font-bold text-stone-900">
        {t('features.title')}
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        (t('features.items') as { title: string; description: string }[]).map((feature: { title: string; description: string }, i: number) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm">
            <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center mb-4">
              {
                i === 0 ? (
                  <svg class="w-6 h-6 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                  </svg>
                ) : i === 1 ? (
                  <svg class="w-6 h-6 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                ) : i === 2 ? (
                  <svg class="w-6 h-6 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 2h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 8.172V3L8 2z"></path>
                  </svg>
                ) : (
                  <svg class="w-6 h-6 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                  </svg>
                )
              }
            </div>
            <h3 class="text-xl font-geologica font-bold text-stone-900 mb-2">{feature.title}</h3>
            <p class="font-alegreya text-stone-600 leading-relaxed">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- Gallery Placeholder -->
<section class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="text-sm font-geologica font-semibold tracking-widest uppercase text-red-800 mb-4 block">{t('gallery.label')}</span>
      <h2 class="text-3xl md:text-4xl font-geologica font-bold text-stone-900">
        {t('gallery.title')}
      </h2>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {
        [0, 1, 2, 3, 4, 5].map(() => (
          <div class="aspect-square bg-stone-200 rounded-xl flex items-center justify-center">
            <span class="text-stone-400 font-geologica text-sm">{t('gallery.imageAlt')}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
