---
import { Image } from 'astro:assets';
import { localizedPath } from '../../i18n/utils';

const allImages = import.meta.glob<{ default: ImageMetadata }>('../../assets/*.{jpg,jpeg,png,webp}', { eager: true });
const productImages: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(allImages)) {
  const filename = path.split('/').pop()!.split('.')[0];
  productImages[filename] = mod.default;
}

interface Props {
  t: <T = unknown>(key: string) => T;
  locale: string;
  slug: string;
}

const { t, locale, slug } = Astro.props;

const features = t('features.items') as { title: string; description: string }[];
---

<!-- Hero -->
<section class="relative py-32 bg-stone-900 overflow-hidden">
  <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_30%_50%,_var(--tw-gradient-stops))] from-red-800 to-transparent"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <span class="text-sm font-geologica font-semibold tracking-widest uppercase text-red-300 mb-4 block">{t('hero.label')}</span>
    <h1 class="text-4xl md:text-6xl font-bold font-geologica text-white leading-tight">
      {t('hero.title')}
    </h1>
    <p class="mt-6 text-lg md:text-xl font-alegreya text-stone-300 max-w-2xl mx-auto leading-relaxed">
      {t('hero.subtitle')}
    </p>
  </div>
</section>

<!-- Overview -->
<section class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
    <div>
      <span class="text-sm font-geologica font-semibold tracking-widest uppercase text-red-800 mb-4 block">{t('overview.label')}</span>
      <h2 class="text-3xl md:text-4xl font-geologica font-bold text-stone-900 leading-tight">
        {t('overview.title')}
      </h2>
      <p class="mt-6 text-lg font-alegreya text-stone-600 leading-relaxed">
        {t('overview.para1')}
      </p>
      <p class="mt-4 text-lg font-alegreya text-stone-600 leading-relaxed">
        {t('overview.para2')}
      </p>
    </div>
    <div class="overflow-hidden rounded-2xl group">
      <Image
        src={productImages[slug]}
        alt={t('hero.title') as string}
        width={960}
        format="webp"
        quality={80}
        loading="lazy"
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
      />
    </div>
  </div>
</section>

<!-- Features -->
<section class="py-24 bg-stone-50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-geologica font-bold text-stone-900">
        {t('features.title')}
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        features.map((feature: { title: string; description: string }, i: number) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm">
            <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center mb-4">
              {
                i === 0 ? (
                  <svg class="w-6 h-6 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
                  </svg>
                ) : i === 1 ? (
                  <svg class="w-6 h-6 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                ) : i === 2 ? (
                  <svg class="w-6 h-6 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                  </svg>
                ) : (
                  <svg class="w-6 h-6 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                  </svg>
                )
              }
            </div>
            <h3 class="text-xl font-geologica font-bold text-stone-900 mb-2">{feature.title}</h3>
            <p class="font-alegreya text-stone-600 leading-relaxed">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-20 bg-stone-50">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-2xl md:text-4xl font-geologica font-bold text-stone-900">
      {t('cta.title')}
    </h2>
    <p class="mt-4 text-lg font-alegreya text-stone-600">
      {t('cta.subtitle')}
    </p>
    <a
      href={localizedPath('/contact', locale)}
      class="mt-8 inline-block bg-red-800 text-white font-geologica font-semibold text-lg px-10 py-4 rounded-full hover:bg-red-900 hover:scale-105 transition-all duration-300 shadow-lg"
    >
      {t('cta.btn')}
    </a>
  </div>
</section>
