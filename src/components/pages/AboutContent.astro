---
import { Image } from 'astro:assets';

const allImages = import.meta.glob<{ default: ImageMetadata }>('../../assets/*.{jpg,jpeg,png,webp}', { eager: true });
const imageMap: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(allImages)) {
  const filename = path.split('/').pop()!.split('.')[0];
  imageMap[filename] = mod.default;
}

interface Props {
  t: <T = unknown>(key: string) => T;
  locale: string;
}

const { t } = Astro.props;

const storyImageKey = t('story.image') as string;
const storyImage = storyImageKey && imageMap[storyImageKey] ? imageMap[storyImageKey] : null;
---

<!-- Hero -->
<section class="relative py-32 bg-stone-900 overflow-hidden">
  <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_50%_50%,_var(--tw-gradient-stops))] from-red-800 to-transparent"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <span class="text-sm font-geologica font-semibold tracking-widest uppercase text-red-300 mb-4 block">{t('hero.label')}</span>
    <h1 class="text-4xl md:text-6xl font-bold font-geologica text-white leading-tight">
      {t('hero.title')}
    </h1>
    <p class="mt-6 text-lg md:text-xl font-alegreya text-stone-300 max-w-2xl mx-auto leading-relaxed">
      {t('hero.subtitle')}
    </p>
  </div>
</section>

<!-- Story -->
<section class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
    <div class="aspect-[4/3] rounded-2xl overflow-hidden">
      {storyImage ? (
        <Image src={storyImage} alt={t('story.imageAlt')} width={800} format="webp" quality={80} class="w-full h-full object-cover" />
      ) : (
        <div class="w-full h-full bg-stone-200 flex items-center justify-center">
          <span class="text-stone-400 font-geologica text-sm">{t('story.imageAlt')}</span>
        </div>
      )}
    </div>
    <div>
      <span class="text-sm font-geologica font-semibold tracking-widest uppercase text-red-800 mb-4 block">{t('story.label')}</span>
      <h2 class="text-3xl md:text-4xl font-geologica font-bold text-stone-900 leading-tight">
        {t('story.title')}
      </h2>
      <p class="mt-6 text-lg font-alegreya text-stone-600 leading-relaxed">
        {t('story.para1')}
      </p>
      <p class="mt-4 text-lg font-alegreya text-stone-600 leading-relaxed">
        {t('story.para2')}
      </p>
    </div>
  </div>
</section>

<!-- Timeline -->
<section class="py-24 bg-stone-50">
  <div class="max-w-3xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-geologica font-bold text-stone-900">
        {t('timeline.title')}
      </h2>
    </div>
    <div class="space-y-12">
      {
        (t('timeline.items') as { year: string; title: string; description: string }[]).map((item: { year: string; title: string; description: string }, i: number, arr: unknown[]) => (
          <div class="flex gap-6">
            <div class="flex flex-col items-center">
              <div class="w-12 h-12 rounded-full bg-red-800 flex items-center justify-center shrink-0">
                <span class="text-white font-geologica font-bold text-sm">{item.year}</span>
              </div>
              {i < arr.length - 1 && <div class="w-px h-full bg-stone-300 mt-2"></div>}
            </div>
            <div class={i < arr.length - 1 ? "pb-8" : ""}>
              <h3 class="text-xl font-geologica font-bold text-stone-900">{item.title}</h3>
              <p class="mt-2 font-alegreya text-stone-600 leading-relaxed">
                {item.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- Team -->
<section class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="text-sm font-geologica font-semibold tracking-widest uppercase text-red-800 mb-4 block">{t('team.label')}</span>
      <h2 class="text-3xl md:text-4xl font-geologica font-bold text-stone-900">
        {t('team.title')}
      </h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
      {
        (t('team.members') as { name: string; role: string; image: string }[]).map((member: { name: string; role: string; image: string }) => {
          const memberImg = member.image && imageMap[member.image] ? imageMap[member.image] : null;
          return (
            <div class="text-center">
              <div class="w-40 h-40 mx-auto rounded-full overflow-hidden mb-4">
                {memberImg ? (
                  <Image src={memberImg} alt={member.name} width={320} format="webp" quality={80} class="w-full h-full object-cover" />
                ) : (
                  <div class="w-full h-full bg-stone-200 flex items-center justify-center">
                    <span class="text-stone-400 font-geologica text-sm">{member.name}</span>
                  </div>
                )}
              </div>
              <h3 class="text-lg font-geologica font-bold text-stone-900">{member.name}</h3>
              <p class="text-sm font-geologica text-red-800">{member.role}</p>
            </div>
          );
        })
      }
    </div>
  </div>
</section>