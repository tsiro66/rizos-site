---
import { Image } from 'astro:assets';

const allImages = import.meta.glob<{ default: ImageMetadata }>('../../assets/*.{jpg,jpeg,png,webp}', { eager: true });
const imageMap: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(allImages)) {
  const filename = path.split('/').pop()!.split('.')[0];
  imageMap[filename] = mod.default;
}

interface Generation {
  period: string;
  title: string;
  text: string;
  image: string;
  imageAlt: string;
}

interface Props {
  t: <T = unknown>(key: string) => T;
  locale: string;
}

const { t } = Astro.props;
const generations = (t('story.generations') as Generation[]) ?? [];
const closing = (t('story.closing') as string[]) ?? [];
---

<!-- Hero -->
<section class="relative py-32 bg-stone-900 overflow-hidden">
  <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_50%_50%,_var(--tw-gradient-stops))] from-red-800 to-transparent"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <span class="text-sm font-geologica font-semibold tracking-widest uppercase text-red-300 mb-4 block">{t('hero.label')}</span>
    <h1 class="text-4xl md:text-6xl font-bold font-geologica text-white leading-tight">
      {t('hero.title')}
    </h1>
    <p class="mt-6 text-lg md:text-xl font-alegreya text-stone-300 max-w-2xl mx-auto leading-relaxed">
      {t('hero.subtitle')}
    </p>
  </div>
</section>

<!-- Story -->
<section class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-2xl">
      <span class="text-sm font-geologica font-semibold tracking-widest uppercase text-red-800 mb-4 block">{t('story.label')}</span>
      <h2 class="text-3xl md:text-4xl font-geologica font-bold text-stone-900 leading-tight">
        {t('story.title')}
      </h2>
    </div>

    <ol class="relative mt-16 space-y-16">
      <span class="absolute left-2 md:left-1/2 top-2 bottom-2 w-px bg-stone-200 -translate-x-1/2" aria-hidden="true"></span>
      {
        generations.map((gen, i) => {
          const image = gen.image && imageMap[gen.image] ? imageMap[gen.image] : null;
          const reversed = i % 2 === 1;
          return (
            <li class="relative">
              <span class="absolute left-2 md:left-1/2 top-2 -translate-x-1/2 w-4 h-4 rounded-full bg-red-800 ring-4 ring-white z-10" />
              <div class={`grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center ${reversed ? 'md:flex-row-reverse' : ''}`}>
                <div class={`pl-10 md:pl-0 ${reversed ? 'md:order-2' : 'md:order-1'}`}>
                  {image ? (
                    <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-lg">
                      <Image src={image} alt={gen.imageAlt} width={800} format="webp" quality={80} class="w-full h-full object-cover" />
                    </div>
                  ) : (
                    <div class="aspect-[4/3] rounded-2xl bg-stone-100 flex items-center justify-center border border-dashed border-stone-300">
                      <span class="text-stone-400 font-geologica text-sm text-center px-6">{gen.imageAlt}</span>
                    </div>
                  )}
                </div>
                <div class={`pl-10 md:pl-0 ${reversed ? 'md:order-1 md:text-right' : 'md:order-2'}`}>
                  <span class="inline-block text-sm font-geologica font-semibold tracking-widest uppercase text-red-800 mb-2">{gen.period}</span>
                  <h3 class="text-2xl md:text-3xl font-geologica font-bold text-stone-900">{gen.title}</h3>
                  <p class="mt-4 text-lg font-alegreya text-stone-600 leading-relaxed">{gen.text}</p>
                </div>
              </div>
            </li>
          );
        })
      }
    </ol>

    <div class="mt-24 max-w-2xl mx-auto text-center">
      <div class="space-y-4">
        {
          closing.map((para) => (
            <p class="text-lg font-alegreya text-stone-700 leading-relaxed">{para}</p>
          ))
        }
      </div>
    </div>
  </div>
</section>