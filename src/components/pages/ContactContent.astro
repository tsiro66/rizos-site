---
interface Props {
  t: <T = unknown>(key: string) => T;
  locale: string;
}

const { t } = Astro.props;
---

<!-- Hero -->
<section class="relative py-32 bg-stone-900 overflow-hidden">
  <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_50%_80%,_var(--tw-gradient-stops))] from-red-800 to-transparent"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <span class="text-sm font-geologica font-semibold tracking-widest uppercase text-red-300 mb-4 block">{t('hero.label')}</span>
    <h1 class="text-4xl md:text-6xl font-bold font-geologica text-white leading-tight">
      {t('hero.title')}
    </h1>
    <p class="mt-6 text-lg md:text-xl font-alegreya text-stone-300 max-w-2xl mx-auto leading-relaxed">
      {t('hero.subtitle')}
    </p>
  </div>
</section>

<!-- Contact Content -->
<section class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-16">
    <!-- Form -->
    <div>
      <h2 class="text-2xl font-geologica font-bold text-stone-900 mb-8">{t('form.title')}</h2>
      <form class="space-y-6">
        <div>
          <label for="name" class="block text-sm font-geologica font-semibold text-stone-700 mb-2">{t('form.nameLabel')}</label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder={t('form.namePlaceholder')}
            class="w-full px-4 py-3 rounded-xl border border-stone-300 font-alegreya text-stone-900 placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-red-800 focus:border-transparent transition"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-geologica font-semibold text-stone-700 mb-2">{t('form.emailLabel')}</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder={t('form.emailPlaceholder')}
            class="w-full px-4 py-3 rounded-xl border border-stone-300 font-alegreya text-stone-900 placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-red-800 focus:border-transparent transition"
          />
        </div>
        <div>
          <label for="phone" class="block text-sm font-geologica font-semibold text-stone-700 mb-2">{t('form.phoneLabel')}</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            placeholder={t('form.phonePlaceholder')}
            class="w-full px-4 py-3 rounded-xl border border-stone-300 font-alegreya text-stone-900 placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-red-800 focus:border-transparent transition"
          />
        </div>
        <div>
          <label for="message" class="block text-sm font-geologica font-semibold text-stone-700 mb-2">{t('form.messageLabel')}</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            placeholder={t('form.messagePlaceholder')}
            class="w-full px-4 py-3 rounded-xl border border-stone-300 font-alegreya text-stone-900 placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-red-800 focus:border-transparent transition resize-none"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full bg-red-800 text-white font-geologica font-semibold text-lg py-4 rounded-full hover:bg-red-900 hover:scale-[1.02] transition-all duration-300 shadow-lg"
        >
          {t('form.submit')}
        </button>
      </form>
    </div>

    <!-- Info -->
    <div class="flex flex-col justify-center">
      <h2 class="text-2xl font-geologica font-bold text-stone-900 mb-8">{t('info.title')}</h2>
      <div class="space-y-8">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-geologica font-bold text-stone-900">{t('info.addressTitle')}</h3>
            <p class="mt-1 font-alegreya text-stone-600">{t('info.address')}</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-geologica font-bold text-stone-900">{t('info.phoneTitle')}</h3>
            <p class="mt-1 font-alegreya text-stone-600">{t('info.phone')}</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-geologica font-bold text-stone-900">{t('info.emailTitle')}</h3>
            <p class="mt-1 font-alegreya text-stone-600">{t('info.email')}</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-geologica font-bold text-stone-900">{t('info.hoursTitle')}</h3>
            <p class="mt-1 font-alegreya text-stone-600">{t('info.weekdays')}</p>
            <p class="font-alegreya text-stone-600">{t('info.weekend')}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Map -->
<section class="h-96 w-full">
  <iframe
    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d456.0650429818253!2d22.287620913324645!3d39.7390305438187!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x135861ca9d6c76d5%3A0x6a915ad27e4ada7a!2zzprOtc69z4TPgc65zrrOriDOoM67zrHPhM61zq_OsSDOpM-Fz4HOvc6szrLOv8-F!5e0!3m2!1sen!2sgr!4v1781009260328!5m2!1sen!2sgr"
    class="w-full h-full border-0"
    allowfullscreen=""
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    title={t('mapAlt')}
  ></iframe>
</section>
