---
import { localizedPath } from '../../i18n/utils';
import { Image } from 'astro:assets';

const allImages = import.meta.glob<{ default: ImageMetadata }>('../../assets/*.{jpg,jpeg,png,webp}', { eager: true });
const productImages: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(allImages)) {
  const filename = path.split('/').pop()!.split('.')[0];
  productImages[filename] = mod.default;
}

const productCollection = import.meta.glob<{ default: Record<string, any> }>('../../content/products/*.json', { eager: true });
const productList: { slug: string; data: Record<string, any> }[] = [];
for (const [path, mod] of Object.entries(productCollection)) {
  const slug = path.split('/').pop()!.replace('.json', '');
  productList.push({ slug, data: mod.default });
}

interface Props {
  t: <T = unknown>(key: string) => T;
  locale: string;
}

const { t, locale } = Astro.props;

const productItems = productList.map(({ slug, data }) => {
  const localeData = data[locale] as { name: string; description: string; imageAlt: string; image: string };
  return { slug, ...localeData };
});
---

<!-- Hero -->
<section class="relative py-32 bg-stone-900 overflow-hidden">
  <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_30%_50%,_var(--tw-gradient-stops))] from-red-800 to-transparent"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <span class="text-sm font-geologica font-semibold tracking-widest uppercase text-red-300 mb-4 block">{t('hero.label')}</span>
    <h1 class="text-4xl md:text-6xl font-bold font-geologica text-white leading-tight">
      {t('hero.title')}
    </h1>
    <p class="mt-6 text-lg md:text-xl font-alegreya text-stone-300 max-w-2xl mx-auto leading-relaxed">
      {t('hero.subtitle')}
    </p>
  </div>
</section>

<!-- Product Grid -->
<section class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        productItems.map((product) => (
          <a href={localizedPath(`/products/${product.slug}`, locale)} class="group rounded-2xl overflow-hidden bg-stone-50 shadow-sm hover:shadow-lg transition-shadow duration-300 block">
            <div class="aspect-square bg-stone-200 flex items-center justify-center overflow-hidden">
              {product.image && productImages[product.image] ? (
                <Image src={productImages[product.image]} alt={product.imageAlt} />
              ) : (
                <span class="text-stone-400 font-geologica text-sm">{product.imageAlt}</span>
              )}
            </div>
            <div class="p-6">
              <h3 class="text-xl font-geologica font-bold text-stone-900">{product.name}</h3>
              <p class="mt-2 font-alegreya text-stone-600 leading-relaxed">
                {product.description}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-20 bg-stone-50">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-2xl md:text-4xl font-geologica font-bold text-stone-900">
      {t('cta.title')}
    </h2>
    <p class="mt-4 text-lg font-alegreya text-stone-600">
      {t('cta.subtitle')}
    </p>
    <a
      href={localizedPath('/contact', locale)}
      class="mt-8 inline-block bg-red-800 text-white font-geologica font-semibold text-lg px-10 py-4 rounded-full hover:bg-red-900 hover:scale-105 transition-all duration-300 shadow-lg"
    >
      {t('cta.btn')}
    </a>
  </div>
</section>
