---
import { localizedPath } from '../../i18n/utils';

interface Props {
  t: (key: string) => string;
  locale: string;
}

const { t, locale } = Astro.props;
---

<!-- Hero -->
<section class="relative py-32 bg-stone-900 overflow-hidden">
  <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_30%_50%,_var(--tw-gradient-stops))] from-red-800 to-transparent"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <span class="text-sm font-geologica font-semibold tracking-widest uppercase text-red-300 mb-4 block">{t('products.hero.label')}</span>
    <h1 class="text-4xl md:text-6xl font-majestic font-bold text-white leading-tight">
      {t('products.hero.title')}
    </h1>
    <p class="mt-6 text-lg md:text-xl font-alegreya text-stone-300 max-w-2xl mx-auto leading-relaxed">
      {t('products.hero.subtitle')}
    </p>
  </div>
</section>

<!-- Product Grid -->
<section class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        t('products.items').map((product: { name: string; description: string; imageAlt: string }) => (
          <div class="group rounded-2xl overflow-hidden bg-stone-50 shadow-sm hover:shadow-lg transition-shadow duration-300">
            <div class="aspect-square bg-stone-200 flex items-center justify-center">
              <span class="text-stone-400 font-geologica text-sm">{product.imageAlt}</span>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-geologica font-bold text-stone-900">{product.name}</h3>
              <p class="mt-2 font-alegreya text-stone-600 leading-relaxed">
                {product.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-20 bg-stone-50">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-2xl md:text-4xl font-geologica font-bold text-stone-900">
      {t('products.cta.title')}
    </h2>
    <p class="mt-4 text-lg font-alegreya text-stone-600">
      {t('products.cta.subtitle')}
    </p>
    <a
      href={localizedPath('/contact', locale)}
      class="mt-8 inline-block bg-red-800 text-white font-geologica font-semibold text-lg px-10 py-4 rounded-full hover:bg-red-900 hover:scale-105 transition-all duration-300 shadow-lg"
    >
      {t('products.cta.btn')}
    </a>
  </div>
</section>
