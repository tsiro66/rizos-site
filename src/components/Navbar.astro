---
import { localizedPath, locales } from '../i18n/utils';

interface Props {
  transparent?: boolean;
  t: <T = unknown>(key: string) => T;
  locale: string;
}
const { transparent = false, t, locale } = Astro.props;

const currentPath = (() => {
  const pathname = Astro.url.pathname;
  if (locale === 'el') return pathname;
  const prefix = `/${locale}`;
  return pathname.startsWith(prefix) ? (pathname.slice(prefix.length) || '/') : pathname;
})();
---

<nav id="main-nav" class:list={[
  "fixed top-0 left-0 right-0 z-[60] transition-all duration-300",
  transparent ? "bg-transparent" : "bg-white shadow-md"
]} data-transparent={transparent}>
  <div class="max-w-11/12 mx-auto flex items-center justify-between px-6 py-5">
    <a href={localizedPath('/', locale)} class:list={[
      "font-geologica text-3xl font-bold uppercase tracking-wide transition-colors duration-300 nav-brand",
      transparent ? "text-white" : "text-red-800"
    ]}>{t('nav.brand')}</a>

    <!-- Desktop links -->
    <ul class="hidden md:flex gap-10 md:gap-16 list-none m-0 p-0 text-lg font-alegreya">
      <li><a href={localizedPath('/about', locale)} class:list={["no-underline transition-colors duration-300 nav-link", transparent ? "text-white/90 hover:text-white" : "text-stone-700 hover:text-stone-900"]}>{t('nav.about')}</a></li>
      <li><a href={localizedPath('/products', locale)} class:list={["no-underline transition-colors duration-300 nav-link", transparent ? "text-white/90 hover:text-white" : "text-stone-700 hover:text-stone-900"]}>{t('nav.products')}</a></li>
      <li><a href={localizedPath('/factory', locale)} class:list={["no-underline transition-colors duration-300 nav-link", transparent ? "text-white/90 hover:text-white" : "text-stone-700 hover:text-stone-900"]}>{t('nav.factory')}</a></li>
      <li><a href={localizedPath('/contact', locale)} class:list={["no-underline transition-colors duration-300 nav-link", transparent ? "text-white/90 hover:text-white" : "text-stone-700 hover:text-stone-900"]}>{t('nav.contact')}</a></li>
    </ul>

    <!-- Locale switcher - desktop -->
    <div class="hidden md:flex items-center gap-1.5 ml-2 text-sm font-alegreya">
      {
        locales.map((l, i) => {
          const label = { el: 'ΕΛ', en: 'EN', de: 'DE' }[l];
          return [
            i > 0 && <span class:list={["locale-pipe transition-colors duration-300", transparent ? "text-white/20" : "text-stone-300"]}>|</span>,
            l === locale
              ? <span class:list={["locale-active transition-colors duration-300 font-semibold", transparent ? "text-white" : "text-stone-900"]}>{label}</span>
              : <a href={localizedPath(currentPath, l)} class:list={["locale-link no-underline transition-colors duration-300", transparent ? "text-white/60 hover:text-white" : "text-stone-500 hover:text-stone-900"]}>{label}</a>
          ];
        })
      }
    </div>

    <!-- Mobile hamburger (2 lines) -->
    <button id="mobile-menu-btn" class="md:hidden flex flex-col justify-center gap-[7px] w-9 h-9 cursor-pointer bg-transparent border-none z-[60]" aria-label="Menu">
      <span class:list={["hamburger-line block w-full h-[2px] transition-all duration-300", transparent ? "bg-white" : "bg-stone-800"]}></span>
      <span class:list={["hamburger-line block w-full h-[2px] transition-all duration-300", transparent ? "bg-white" : "bg-stone-800"]}></span>
    </button>
  </div>
</nav>

<!-- Fullscreen mobile menu -->
<div id="mobile-menu" class="fixed inset-0 z-[55] bg-red-800 flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-300">
  <a href={localizedPath('/about', locale)} class="text-white text-3xl font-alegreya no-underline hover:opacity-80 transition-opacity">{t('nav.about')}</a>
  <a href={localizedPath('/products', locale)} class="text-white text-3xl font-alegreya no-underline hover:opacity-80 transition-opacity">{t('nav.products')}</a>
  <a href={localizedPath('/factory', locale)} class="text-white text-3xl font-alegreya no-underline hover:opacity-80 transition-opacity">{t('nav.factory')}</a>
  <a href={localizedPath('/contact', locale)} class="text-white text-3xl font-alegreya no-underline hover:opacity-80 transition-opacity">{t('nav.contact')}</a>

  <!-- Locale switcher - mobile -->
  <div class="flex items-center gap-3 mt-6 text-xl font-alegreya">
    {
      locales.map((l, i) => {
        const label = { el: 'ΕΛ', en: 'EN', de: 'DE' }[l];
        return [
          i > 0 && <span class="text-white/30">|</span>,
          l === locale
            ? <span class="text-white font-bold">{label}</span>
            : <a href={localizedPath(currentPath, l)} class="text-white/60 hover:text-white transition-colors no-underline">{label}</a>
        ];
      })
    }
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const nav = document.getElementById('main-nav');
    if (!nav) return;

    const brand = nav.querySelector('.nav-brand') as HTMLElement;
    const links = nav.querySelectorAll('.nav-link');
    const localeLinks = nav.querySelectorAll('.locale-link');
    const localePipes = nav.querySelectorAll('.locale-pipe');
    const localeActive = nav.querySelectorAll('.locale-active');
    const hamburgerLines = nav.querySelectorAll('.hamburger-line');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    let menuOpen = false;

    function updateHamburgerColor(scrolled: boolean) {
      if (menuOpen) return;
      const color = scrolled ? 'bg-stone-800' : 'bg-white';
      const removeColor = scrolled ? 'bg-white' : 'bg-stone-800';
      hamburgerLines.forEach(l => {
        l.classList.remove(removeColor);
        l.classList.add(color);
      });
    }

    function toggleMenu() {
      menuOpen = !menuOpen;
      if (menuOpen) {
        mobileMenu!.classList.remove('opacity-0', 'pointer-events-none');
        mobileMenu!.classList.add('opacity-100', 'pointer-events-auto');
        nav!.classList.remove('bg-transparent', 'bg-white', 'shadow-md');
        nav!.classList.add('bg-red-800');
        brand?.classList.remove('text-red-800');
        brand?.classList.add('text-white');
        hamburgerLines.forEach(l => {
          l.classList.remove('bg-stone-800');
          l.classList.add('bg-white');
        });
        localeLinks.forEach(l => {
          l.classList.remove('text-stone-500', 'hover:text-stone-900');
          l.classList.add('text-white/60', 'hover:text-white');
        });
        localePipes.forEach(l => {
          l.classList.remove('text-stone-300');
          l.classList.add('text-white/20');
        });
        localeActive.forEach(l => {
          l.classList.remove('text-stone-900');
          l.classList.add('text-white');
        });
        const lines = Array.from(hamburgerLines) as HTMLElement[];
        lines[0].style.transform = 'translateY(4.5px) rotate(45deg)';
        lines[1].style.transform = 'translateY(-4.5px) rotate(-45deg)';
        document.body.style.overflow = 'hidden';
      } else {
        mobileMenu!.classList.add('opacity-0', 'pointer-events-none');
        mobileMenu!.classList.remove('opacity-100', 'pointer-events-auto');
        nav!.classList.remove('bg-red-800');
        if (isTransparent && window.scrollY <= 80) {
          nav!.classList.add('bg-transparent');
          brand?.classList.remove('text-red-800');
          brand?.classList.add('text-white');
          localeLinks.forEach(l => {
            l.classList.remove('text-stone-500', 'hover:text-stone-900');
            l.classList.add('text-white/60', 'hover:text-white');
          });
          localePipes.forEach(l => {
            l.classList.remove('text-stone-300');
            l.classList.add('text-white/20');
          });
          localeActive.forEach(l => {
            l.classList.remove('text-stone-900');
            l.classList.add('text-white');
          });
        } else {
          nav!.classList.add('bg-white', 'shadow-md');
          brand?.classList.remove('text-white');
          brand?.classList.add('text-red-800');
          links.forEach(l => {
            l.classList.remove('text-white/90', 'hover:text-white');
            l.classList.add('text-stone-700', 'hover:text-stone-900');
          });
          localeLinks.forEach(l => {
            l.classList.remove('text-white/60', 'hover:text-white');
            l.classList.add('text-stone-500', 'hover:text-stone-900');
          });
          localePipes.forEach(l => {
            l.classList.remove('text-white/20');
            l.classList.add('text-stone-300');
          });
          localeActive.forEach(l => {
            l.classList.remove('text-white');
            l.classList.add('text-stone-900');
          });
        }
        const lines = Array.from(hamburgerLines) as HTMLElement[];
        lines[0].style.transform = '';
        lines[1].style.transform = '';
        document.body.style.overflow = '';
        updateHamburgerColor(window.scrollY > 80);
      }
    }

    menuBtn?.addEventListener('click', toggleMenu);

    mobileMenu?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        if (menuOpen) toggleMenu();
      });
    });

    const isTransparent = nav!.dataset.transparent === 'true';

    function onScroll() {
      if (!isTransparent) return;
      const scrolled = window.scrollY > 80;
      if (scrolled) {
        nav!.classList.remove('bg-transparent');
        nav!.classList.add('bg-white', 'shadow-md');
        nav!.style.padding = '';
        brand?.classList.remove('text-white');
        brand?.classList.add('text-red-800');
        links.forEach(l => {
          l.classList.remove('text-white/90', 'hover:text-white');
          l.classList.add('text-stone-700', 'hover:text-stone-900');
        });
        localeLinks.forEach(l => {
          l.classList.remove('text-white/60', 'hover:text-white');
          l.classList.add('text-stone-500', 'hover:text-stone-900');
        });
        localePipes.forEach(l => {
          l.classList.remove('text-white/20');
          l.classList.add('text-stone-300');
        });
        localeActive.forEach(l => {
          l.classList.remove('text-white');
          l.classList.add('text-stone-900');
        });
      } else {
        nav!.classList.add('bg-transparent');
        nav!.classList.remove('bg-white', 'shadow-md');
        brand?.classList.add('text-white');
        brand?.classList.remove('text-red-800');
        links.forEach(l => {
          l.classList.add('text-white/90', 'hover:text-white');
          l.classList.remove('text-stone-700', 'hover:text-stone-900');
        });
        localeLinks.forEach(l => {
          l.classList.add('text-white/60', 'hover:text-white');
          l.classList.remove('text-stone-500', 'hover:text-stone-900');
        });
        localePipes.forEach(l => {
          l.classList.add('text-white/20');
          l.classList.remove('text-stone-300');
        });
        localeActive.forEach(l => {
          l.classList.add('text-white');
          l.classList.remove('text-stone-900');
        });
      }
      updateHamburgerColor(scrolled);
    }

    if (isTransparent) {
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
  });
</script>
