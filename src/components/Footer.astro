---
import { Image } from 'astro:assets';
import { localizedPath } from '../i18n/utils';
import logoImg from '../assets/logo.png';

interface Props {
  t: <T = unknown>(key: string) => T;
  locale: string;
}

const { t, locale } = Astro.props;
---

<footer id="site-footer" class="fixed bottom-0 left-0 right-0 z-0 bg-red-800 text-white">
  <div class="max-w-11/12 mx-auto px-6 py-16 md:py-26">
    <!-- Top row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
      <!-- Brand -->
      <div>
        <a href={localizedPath('/', locale)} class="inline-block mb-4">
          <Image src={logoImg} alt="Rizos" class="h-16 w-auto" />
        </a>
        <p class="font-alegreya text-lg text-white/70 max-w-xs leading-relaxed">
          {t('footer.description')}
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-geologica font-semibold text-sm uppercase tracking-widest text-white/50 mb-6">{t('footer.navTitle')}</h3>
        <ul class="space-y-3 list-none m-0 p-0">
          <li><a href={localizedPath('/products', locale)} class="font-alegreya text-lg text-white/80 no-underline hover:text-white transition-colors duration-300">{t('footer.products')}</a></li>
          <li><a href={localizedPath('/factory', locale)} class="font-alegreya text-lg text-white/80 no-underline hover:text-white transition-colors duration-300">{t('footer.factory')}</a></li>
          <li><a href={localizedPath('/about', locale)} class="font-alegreya text-lg text-white/80 no-underline hover:text-white transition-colors duration-300">{t('footer.about')}</a></li>
          <li><a href={localizedPath('/contact', locale)} class="font-alegreya text-lg text-white/80 no-underline hover:text-white transition-colors duration-300">{t('footer.contact')}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-geologica font-semibold text-sm uppercase tracking-widest text-white/50 mb-6">{t('footer.contactTitle')}</h3>
        <ul class="space-y-3 list-none m-0 p-0 font-alegreya text-lg text-white/80">
          <li>{t('footer.email')}</li>
          <li>{t('footer.phone')}</li>
          <li>{t('footer.country')}</li>
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <div class="mt-16 pt-8 border-t border-white/20 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="font-alegreya text-sm text-white/60">{String(t('footer.copyright')).replace('{year}', String(new Date().getFullYear()))}</p>
      <p class="font-alegreya text-sm text-white/40">{t('footer.madeIn')}</p>
    </div>
  </div>
</footer>

<script>
  document.addEventListener('astro:page-load', () => {
    const footer = document.getElementById('site-footer');
    const main = document.querySelector('main');
    if (!footer || !main) return;

    function syncHeight() {
      const h = footer!.offsetHeight;
      (main as HTMLElement).style.marginBottom = h + 'px';
    }

    syncHeight();
    window.addEventListener('resize', syncHeight, { passive: true });
  });
</script>
