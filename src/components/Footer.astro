<footer id="site-footer" class="fixed bottom-0 left-0 right-0 z-0 bg-red-800 text-white">
	<div class="max-w-11/12 mx-auto px-6 py-16 md:py-24">
		<!-- Top row -->
		<div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
			<!-- Brand -->
			<div>
				<a href="/" class="hidden md:inline font-geologica text-4xl font-bold uppercase tracking-wide text-white">ΡΙΖΟΣ</a>
				<p class="mt-4 font-alegreya text-lg text-white/70 max-w-xs leading-relaxed">
					Αγνά και φυσικά προϊόντα, από τα βουνά της Ελλάδας στο τραπέζι σας.
				</p>
			</div>

			<!-- Navigation -->
			<div>
				<h3 class="font-geologica font-semibold text-sm uppercase tracking-widest text-white/50 mb-6">Πλοήγηση</h3>
				<ul class="space-y-3 list-none m-0 p-0">
					<li><a href="/products" class="font-alegreya text-lg text-white/80 no-underline hover:text-white transition-colors duration-300">Προϊόντα</a></li>
					<li><a href="/factory" class="font-alegreya text-lg text-white/80 no-underline hover:text-white transition-colors duration-300">Εγκαταστάσεις</a></li>
					<li><a href="/about" class="font-alegreya text-lg text-white/80 no-underline hover:text-white transition-colors duration-300">Σχετικά με μας</a></li>
					<li><a href="/contact" class="font-alegreya text-lg text-white/80 no-underline hover:text-white transition-colors duration-300">Επικοινωνία</a></li>
				</ul>
			</div>

			<!-- Contact -->
			<div>
				<h3 class="font-geologica font-semibold text-sm uppercase tracking-widest text-white/50 mb-6">Επικοινωνία</h3>
				<ul class="space-y-3 list-none m-0 p-0 font-alegreya text-lg text-white/80">
					<li>info@rizos.gr</li>
					<li>+30 210 000 0000</li>
					<li>Ελλάδα</li>
				</ul>
			</div>
		</div>

		<!-- Divider -->
		<div class="mt-16 pt-8 border-t border-white/20 flex flex-col md:flex-row items-center justify-between gap-4">
			<p class="font-alegreya text-sm text-white/60">&copy; {new Date().getFullYear()} Ρίζος. Όλα τα δικαιώματα κατοχυρωμένα.</p>
			<p class="font-alegreya text-sm text-white/40">Φτιαγμένο με αγάπη στην Ελλάδα</p>
		</div>
	</div>
</footer>

<script>
	document.addEventListener('astro:page-load', () => {
		const footer = document.getElementById('site-footer');
		const main = document.querySelector('main');
		if (!footer || !main) return;

		function syncHeight() {
			const h = footer!.offsetHeight;
			(main as HTMLElement).style.marginBottom = h + 'px';
		}

		syncHeight();
		window.addEventListener('resize', syncHeight, { passive: true });
	});
</script>
